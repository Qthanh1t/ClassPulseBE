@sessionId = ca58370c-3f9e-4730-97f5-3ea05ff8ed94


### ── HAPPY PATH ────────────────────────────────────────────

### [1] Teacher bắt đầu session
# → Expect 201, data.status = "active"
# → Copy data.id → sessionId (dùng cho tất cả bước tiếp)
POST {{baseUrl}}/api/v1/classrooms/{{classroomId}}/sessions
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{}

### [2] Teacher bắt đầu session (kèm scheduleId nếu có)
# Bỏ qua nếu không có schedule
POST {{baseUrl}}/api/v1/classrooms/{{classroomId}}/sessions
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{
  "scheduleId": "00000000-0000-0000-0000-000000000000"
}

### [3] Xem danh sách session của lớp (teacher)
# → Expect 200, data là mảng, meta có totalCount
GET {{baseUrl}}/api/v1/classrooms/{{classroomId}}/sessions?page=1&limit=20
Authorization: Bearer {{teacherToken}}

### [4] Xem chi tiết session
# → Expect 200, data.status = "active"
GET {{baseUrl}}/api/v1/sessions/{{sessionId}}
Authorization: Bearer {{teacherToken}}

### [5] Student 1 join session
# → Expect 200, data.wsTicket (dùng cho WebSocket M13)
POST {{baseUrl}}/api/v1/sessions/{{sessionId}}/join
Authorization: Bearer {{student1Token}}

### [6] Student 2 join session
POST {{baseUrl}}/api/v1/sessions/{{sessionId}}/join
Authorization: Bearer {{student2Token}}

### [7] Xem danh sách presence (teacher hoặc student đã join)
# → Expect 200, data là mảng 2 student, isOnline = true
GET {{baseUrl}}/api/v1/sessions/{{sessionId}}/presence
Authorization: Bearer {{teacherToken}}

### [8] Student 1 leave session
# → Expect 204 No Content
POST {{baseUrl}}/api/v1/sessions/{{sessionId}}/leave
Authorization: Bearer {{student1Token}}

### [9] Xem presence sau khi student 1 leave
# → data[0].isOnline = false (có leftAt, không còn trong Redis set)
GET {{baseUrl}}/api/v1/sessions/{{sessionId}}/presence
Authorization: Bearer {{teacherToken}}

### [10] Student 1 rejoin session (presence được re-activate)
POST {{baseUrl}}/api/v1/sessions/{{sessionId}}/join
Authorization: Bearer {{student1Token}}

### [11] Teacher kết thúc session
# → Expect 200, data.status = "ended", data.durationMinutes > 0
POST {{baseUrl}}/api/v1/sessions/{{sessionId}}/end
Authorization: Bearer {{teacherToken}}


### ── ERROR CASES ────────────────────────────────────────────

### [E1] Teacher bắt đầu session thứ 2 khi đã có session active
# → Expect 409, error.code = "SESSION_ALREADY_ACTIVE"
# (Chỉ test được trước khi end session ở bước [11])
POST {{baseUrl}}/api/v1/classrooms/{{classroomId}}/sessions
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{}

### [E2] Student cố join session đã kết thúc
# → Expect 404 hoặc 400 (session không còn active)
POST {{baseUrl}}/api/v1/sessions/{{sessionId}}/join
Authorization: Bearer {{student1Token}}

### [E3] Teacher (không phải owner) cố end session của người khác
# → Expect 403
POST {{baseUrl}}/api/v1/sessions/{{sessionId}}/end
Authorization: Bearer {{student1Token}}

### [E4] Truy cập presence khi chưa join (student chưa tham gia)
# Đăng ký 1 student mới chưa join lớp, dùng token đó
# → Expect 403
GET {{baseUrl}}/api/v1/sessions/{{sessionId}}/presence
Authorization: Bearer <UNKNOWN_STUDENT_TOKEN>

### [E5] Get session không tồn tại
# → Expect 404
GET {{baseUrl}}/api/v1/sessions/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{teacherToken}}
