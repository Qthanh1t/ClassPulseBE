# =============================================================================
# ClassPulse — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# --- Database (PostgreSQL 16) ---
DB_URL=jdbc:postgresql://localhost:5432/classpulse
DB_USER=classpulse
DB_PASSWORD=classpulse_dev

# --- Redis 7 ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
# Generate: openssl rand -hex 64
# Must be >= 64 chars for HS512
JWT_SECRET=change_me_must_be_at_least_64_chars_for_hs512_algorithm_security_x

# --- MinIO / S3 ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=classpulse

# --- Coturn (WebRTC TURN/STUN) ---
# Must match static-auth-secret in turnserver.conf
TURN_SECRET=classpulse_turn_dev_secret
TURN_SERVER=localhost:3478

# --- App ---
PORT=8080
SPRING_PROFILES_ACTIVE=dev
